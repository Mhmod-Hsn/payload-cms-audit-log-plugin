{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true,
      "react": {
        "runtime": "automatic"
      }
    },
    "target": "es2022",
    "externalHelpers": true,
    "keepClassNames": true,
    "baseUrl": ".",
    "paths": {
      "*": ["./src/*"]
    }
  },
  "module": {
    "type": "es6"
  },
  "sourceMaps": true,
  "minify": false
}
